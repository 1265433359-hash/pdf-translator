/* White 纯白 theme — generated by scripts/gen_themes.py; edit there, not here */
* { font-family: "Segoe UI", "Microsoft YaHei", "PingFang SC", sans-serif; }
QWidget { background: #ffffff; color: #18181b; font-size: 14px; }
QMainWindow, QDialog { background: #ffffff; }
QLabel { background: transparent; }

QToolBar { background: #f4f4f5; border: none; border-bottom: 1px solid #e4e4e7;
           spacing: 3px; padding: 6px 8px; }
QToolBar::separator { background: #e4e4e7; width: 1px; margin: 5px 6px; }

/* left navigation sidebar */
QToolBar#sidebar { background: #f4f4f5; border: none; border-right: 1px solid #e4e4e7;
    border-bottom: none; spacing: 4px; padding: 14px 10px; min-width: 138px; }
QToolBar#sidebar QToolButton { text-align: left; padding: 10px 14px; min-width: 110px;
    border-radius: 10px; font-size: 14px; }
QToolBar#sidebar QToolButton:hover { background: #e6e6e8; }
QToolBar#sidebar QToolButton:checked { background: #d6d6d9; color: #3f3f46; font-weight: 600; }

QToolButton { background: transparent; color: #18181b; border: none;
              padding: 6px 10px; border-radius: 8px; }
QToolButton:hover { background: #e6e6e8; }
QToolButton:pressed { background: #d6d6d9; }
QToolButton:checked { background: #d6d6d9; }
QToolButton::menu-indicator { image: none; }

QPushButton { background: #3f3f46; color: #ffffff; border: none;
              padding: 7px 16px; border-radius: 8px; font-weight: 600; }
QPushButton:hover { background: #52525b; }
QPushButton:pressed { background: #27272a; }
QPushButton:disabled { background: #e4e4e7; color: #71717a; }

QLineEdit, QSpinBox, QComboBox, QPlainTextEdit, QTextEdit {
    background: #ffffff; color: #18181b; border: 1px solid #e4e4e7;
    border-radius: 8px; padding: 6px 9px; selection-background-color: #3f3f46;
    selection-color: #ffffff; }
QLineEdit:focus, QSpinBox:focus, QComboBox:focus, QPlainTextEdit:focus {
    border: 1px solid #3f3f46; }
QComboBox:hover { border: 1px solid #3f3f46; }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView { background: #ffffff; color: #18181b;
    border: 1px solid #e4e4e7; border-radius: 8px; outline: none;
    selection-background-color: #e6e6e8; selection-color: #18181b; padding: 4px; }
QSpinBox::up-button, QSpinBox::down-button { width: 16px; border: none; background: #e6e6e8; }

QMenu { background: #ffffff; color: #18181b; border: 1px solid #e4e4e7;
         border-radius: 10px; padding: 6px; }
QMenu::item { padding: 6px 22px 6px 14px; border-radius: 6px; }
QMenu::item:selected { background: #e6e6e8; }
QMenu::separator { height: 1px; background: #e4e4e7; margin: 5px 8px; }

QFrame { background: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px; }
QGroupBox { background: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px;
            margin-top: 12px; padding: 10px; }
QGroupBox::title { subcontrol-origin: margin; left: 12px; padding: 0 4px; color: #71717a; }
QScrollArea { background: transparent; border: none; }
QDockWidget { titlebar-close-icon: none; color: #71717a; }
QDockWidget::title { background: #f4f4f5; padding: 8px 12px; border-bottom: 1px solid #e4e4e7; }
QTreeWidget { background: #ffffff; border: none; outline: none; }
QTreeWidget::item { padding: 5px 4px; border-radius: 6px; }
QTreeWidget::item:hover { background: #e6e6e8; }
QTreeWidget::item:selected { background: #d6d6d9; color: #3f3f46; }

QScrollBar:vertical { background: transparent; width: 11px; margin: 2px; }
QScrollBar::handle:vertical { background: #d4d4d8; border-radius: 5px; min-height: 28px; }
QScrollBar::handle:vertical:hover { background: #a1a1aa; }
QScrollBar:horizontal { background: transparent; height: 11px; margin: 2px; }
QScrollBar::handle:horizontal { background: #d4d4d8; border-radius: 5px; min-width: 28px; }
QScrollBar::add-line, QScrollBar::sub-line { width: 0; height: 0; }
QScrollBar::add-page, QScrollBar::sub-page { background: transparent; }

QToolTip { background: #ffffff; color: #18181b; border: 1px solid #e4e4e7;
           padding: 4px 8px; border-radius: 6px; }
QTableWidget { background: #ffffff; gridline-color: #e4e4e7; border: 1px solid #e4e4e7;
               border-radius: 8px; }
QHeaderView::section { background: #f4f4f5; color: #71717a; border: none; padding: 6px; }

#floatResult { background: #ffffff; border: 1px solid #e4e4e7; border-radius: 16px; }

#homePage { background: #ffffff; }
#openCard { background: #ffffff; border: 1px solid #e4e4e7; border-radius: 16px; }
#openCard:hover { border: 1px solid #3f3f46; background: #e6e6e8; }
#openTitle { font-size: 19px; font-weight: 700; color: #18181b; }
#recentTitle { font-size: 24px; font-weight: 800; color: #18181b; }
#recentRow { background: transparent; border: 1px solid transparent; border-radius: 12px; }
#recentRow:hover { background: #e6e6e8; border: 1px solid #e4e4e7; }
#recentName { font-size: 15px; color: #18181b; }
#recentDate { color: #71717a; font-size: 13px; }
