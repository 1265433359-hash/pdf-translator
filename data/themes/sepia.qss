QWidget { background: #f4ecd8; color: #5b4636; font-family: "Segoe UI","Microsoft YaHei"; }
QToolBar { background: #ece0c4; border-bottom: 1px solid #ddcfae; }
QPushButton { background: #a9743f; color: white; border: none; padding: 4px 10px; border-radius: 6px; }
QPushButton:hover { background: #946231; }
QLineEdit, QSpinBox, QComboBox { background: #fbf5e6; color: #5b4636; border: 1px solid #d8c39a; border-radius: 6px; padding: 3px; }
QFrame { background: #fbf5e6; border: 1px solid #cdb583; border-radius: 9px; }
QScrollArea { border: none; }
